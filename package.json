{
  "name": "imperium-annuity",
  "version": "1.0.0",
  "description": "Tokenized annuity smart contracts and CLI agent for Hedera Network",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:contracts": "hardhat test test/annuity/01-annuity.flow.test.js test/annuity/02-annuity.payments.test.js test/annuity/03-annuity.transfer.test.js test/annuity/04-annuity.security.test.js test/annuity/05-annuity.reentrancy.test.js",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "deploy:hedera": "hardhat run scripts/deploy.js --network hederaTestnet",
    "node": "hardhat node",
    "build": "cd web && npm install && npm run build",
    "start": "node api/imperium-api.js",
    "start:local": "./start.sh",
    "start:hedera": "./start.sh --network hedera-testnet",
    "demo": "node test/annuity/demo-bot.js",
    "demo:hedera": "node test/annuity/demo-bot.js --network hedera-testnet",
    "dev:web": "cd web && npm run dev",
    "build:web": "cd web && npm run build",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed"
  },
  "dependencies": {
    "@hashgraphonline/standards-sdk": "^0.1.165",
    "@langchain/anthropic": "^1.3.23",
    "@langchain/core": "^1.1.32",
    "@openzeppelin/contracts": "^5.4.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "hedera-agent-kit": "^3.8.1",
    "langchain": "^1.2.32",
    "node-fetch": "^2.6.7",
    "web3": "^4.16.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@playwright/test": "^1.58.2",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "chai": "^4.5.0",
    "hardhat": "^2.28.6",
    "hardhat-gas-reporter": "^1.0.10",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=18"
  }
}
