# Hedera Testnet
# 1. Create account at https://portal.hedera.com
# 2. Fund with testnet HBAR via faucet
# 3. Uncomment and fill in values below

# HEDERA_TESTNET_ACCOUNT_ID=0.0.xxxxx
# HEDERA_TESTNET_PRIVATE_KEY=0x...
# HEDERA_TESTNET_RPC_URL=https://testnet.hashio.io/api

# HOL Registry Broker (HCS-10)
# Auto-populated after: node agent/hol-registry.js create
# State is persisted to deployments/hol-agent.json
# REGISTRY_URL=https://moonscape.tech
